<resources>
    <!--
        Base application theme.
        Compose handles theming via MaterialTheme — this style is only used
        for the splash/launch window background before Compose renders.
    -->
    <style name="Theme.TaskManager" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
